# ──────────────────────────────────────────────────────────────
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.
# ──────────────────────────────────────────────────────────────

# ── Neon PostgreSQL ───────────────────────────────────────────
# From your Neon project → Connection Details → "Prisma" tab
# It looks like: postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require"

# If you enable connection pooling in Neon, also set DIRECT_URL
# and uncomment the directUrl line in prisma/schema.prisma:
# DIRECT_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require"

# ── NextAuth ──────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-random-secret-here"

# The URL your app runs at (no trailing slash)
NEXTAUTH_URL="http://localhost:3000"
